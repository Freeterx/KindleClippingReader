{
  "name": "Kindle Clipping Reader",
  "description": "Import, browse, and organize Kindle clippings with highlights, notes, and bookmarks. Export to OneNote or clipboard.",
  "version": "1.0",
  "manifest_version": 3,
  "permissions": [
	"tabs",
  "downloads",
  "storage",
  "identity"
],
  
  "action": {},
  
  "background": {
    "service_worker": "background.js"
  },
  
  "web_accessible_resources": [
    {
      "matches": ["<all_urls>"],
      "resources": ["note.html"]
    }
  ],
  
  "icons": {
    "16": "images/icon-16.png",
    "32": "images/icon-32.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  }  
}